{
  "name": "kodiak-cast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kodiak Cast - plan, launch, and maintain podcasts.",
  "scripts": {
    "dev": "node server/dev.mjs",
    "dev:vite": "vite --host 0.0.0.0",
    "api": "node server/ai-gateway.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
